{
  "table": "orders",
  "timezone": "Asia/Ho_Chi_Minh",
  "images_dir": "flowers",
  "fields": [
    {"name": "id", "type": "integer", "auto": "increment"},
    {"name": "status", "type": "text", "default": "new", "role": "status"},
    {"name": "customer_name", "type": "text", "required": true},
    {"name": "recipient_name", "type": "text", "required": true},
    {"name": "recipient_phone", "type": "text", "required": true},
    {"name": "recipient_address", "type": "text", "required": true},
    {"name": "items", "type": "text", "required": true},
    {"name": "price", "type": "integer", "role": "price", "required": true},
    {"name": "delivery_time", "type": "text"},
    {"name": "note", "type": "text"},
    {"name": "sender_id", "type": "text", "role": "owner"},
    {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
  ],
  "statuses": ["new", "completed", "cancelled"]
}
