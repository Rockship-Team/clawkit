{
  "tables": {
    "transactions": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "type", "type": "text", "required": true},
        {"name": "contact_id", "type": "integer", "ref": "contacts"},
        {"name": "gold_weight_g", "type": "text"},
        {"name": "gold_price_ref", "type": "integer"},
        {"name": "labor_charge", "type": "integer", "default": "0"},
        {"name": "stone_charge", "type": "integer", "default": "0"},
        {"name": "old_gold_credit", "type": "integer", "default": "0"},
        {"name": "total", "type": "integer", "role": "price"},
        {"name": "payment_method", "type": "text"},
        {"name": "payment_status", "type": "text", "default": "pending"},
        {"name": "customer_id_doc", "type": "text"},
        {"name": "notes", "type": "text"},
        {"name": "status", "type": "text", "default": "pending", "role": "status"},
        {"name": "sender_id", "type": "text", "role": "owner"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["pending", "completed", "cancelled"]
    },
    "products": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "barcode", "type": "text"},
        {"name": "type", "type": "text"},
        {"name": "category", "type": "text"},
        {"name": "name", "type": "text", "required": true},
        {"name": "gold_purity", "type": "text"},
        {"name": "gold_weight_g", "type": "text"},
        {"name": "total_weight_g", "type": "text"},
        {"name": "stone_type", "type": "text"},
        {"name": "labor_cost", "type": "integer"},
        {"name": "stone_cost", "type": "integer"},
        {"name": "total_cost", "type": "integer"},
        {"name": "selling_price", "type": "integer", "role": "price"},
        {"name": "location", "type": "text"},
        {"name": "status", "type": "text", "default": "in_stock", "role": "status"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["in_stock", "on_display", "sold", "in_repair", "consigned"]
    },
    "price_board": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "gold_type", "type": "text", "required": true},
        {"name": "buy_price", "type": "integer"},
        {"name": "sell_price", "type": "integer"},
        {"name": "unit", "type": "text", "default": "gram"},
        {"name": "source", "type": "text"},
        {"name": "effective_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ]
    },
    "contacts": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "full_name", "type": "text", "required": true},
        {"name": "phone", "type": "text"},
        {"name": "id_number", "type": "text"},
        {"name": "address", "type": "text"},
        {"name": "status", "type": "text", "default": "customer", "role": "status"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["lead", "customer", "vip", "inactive"]
    }
  },
  "primary": "transactions",
  "timezone": "Asia/Ho_Chi_Minh"
}
