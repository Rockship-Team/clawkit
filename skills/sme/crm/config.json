{
  "version": "1.0.0",
  "requires_bins": ["sme-cli"],
  "setup_prompts": [
    {
      "key": "cosmo_base_url",
      "label": "COSMO base URL",
      "placeholder": "https://api.cosmo.example.com"
    },
    {
      "key": "cosmo_auth_email",
      "label": "COSMO login email",
      "placeholder": "you@company.com"
    },
    {
      "key": "apollo_api_key",
      "label": "Apollo.io API key (optional — de lai trong neu khong co)",
      "placeholder": ""
    }
  ],
  "exclude": ["cmd", "*.go"]
}
