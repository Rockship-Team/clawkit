{
  "tables": {
    "students": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "contact_id", "type": "integer", "ref": "contacts"},
        {"name": "current_school", "type": "text"},
        {"name": "current_grade", "type": "text"},
        {"name": "gpa", "type": "text"},
        {"name": "target_country", "type": "text"},
        {"name": "target_level", "type": "text"},
        {"name": "target_major", "type": "text"},
        {"name": "budget_range", "type": "text"},
        {"name": "english_level", "type": "text"},
        {"name": "intake_season", "type": "text"},
        {"name": "counselor", "type": "text"},
        {"name": "status", "type": "text", "default": "inquiry", "role": "status"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["inquiry", "consulting", "preparing", "applied", "admitted", "visa", "enrolled"]
    },
    "applications": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "student_id", "type": "integer", "ref": "students"},
        {"name": "university", "type": "text", "required": true},
        {"name": "program", "type": "text", "required": true},
        {"name": "country", "type": "text"},
        {"name": "status", "type": "text", "default": "preparing", "role": "status"},
        {"name": "submitted_date", "type": "text"},
        {"name": "decision_date", "type": "text"},
        {"name": "scholarship_amount", "type": "integer"},
        {"name": "notes", "type": "text"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["preparing", "submitted", "under_review", "offer", "accepted", "rejected"]
    },
    "test_scores": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "student_id", "type": "integer", "ref": "students"},
        {"name": "test_type", "type": "text", "required": true},
        {"name": "overall_score", "type": "text"},
        {"name": "sub_scores", "type": "text"},
        {"name": "test_date", "type": "text"},
        {"name": "target_score", "type": "text"},
        {"name": "is_official", "type": "text", "default": "false"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ]
    },
    "contacts": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "full_name", "type": "text", "required": true},
        {"name": "phone", "type": "text"},
        {"name": "email", "type": "text"},
        {"name": "address", "type": "text"},
        {"name": "source", "type": "text"},
        {"name": "status", "type": "text", "default": "lead", "role": "status"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["lead", "prospect", "customer", "inactive"]
    }
  },
  "primary": "students",
  "timezone": "Asia/Ho_Chi_Minh"
}
