{
  "tables": {
    "orders": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "order_number", "type": "text"},
        {"name": "customer_id", "type": "integer", "ref": "contacts"},
        {"name": "type", "type": "text", "default": "wholesale"},
        {"name": "status", "type": "text", "default": "pending", "role": "status"},
        {"name": "subtotal", "type": "integer"},
        {"name": "tax_amount", "type": "integer", "default": "0"},
        {"name": "shipping_fee", "type": "integer", "default": "0"},
        {"name": "total", "type": "integer", "role": "price"},
        {"name": "delivery_date", "type": "text"},
        {"name": "delivery_address", "type": "text"},
        {"name": "payment_status", "type": "text", "default": "pending"},
        {"name": "notes", "type": "text"},
        {"name": "salesperson", "type": "text"},
        {"name": "sender_id", "type": "text", "role": "owner"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["pending", "confirmed", "picking", "shipped", "delivered", "cancelled"]
    },
    "order_items": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "order_id", "type": "integer", "ref": "orders"},
        {"name": "product_id", "type": "integer", "ref": "products"},
        {"name": "product_name", "type": "text"},
        {"name": "batch_number", "type": "text"},
        {"name": "quantity", "type": "integer", "required": true},
        {"name": "unit", "type": "text"},
        {"name": "unit_price", "type": "integer", "role": "price"},
        {"name": "line_total", "type": "integer"}
      ]
    },
    "products": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "sku", "type": "text"},
        {"name": "name", "type": "text", "required": true},
        {"name": "category", "type": "text"},
        {"name": "brand", "type": "text"},
        {"name": "supplier", "type": "text"},
        {"name": "unit", "type": "text"},
        {"name": "cost_price", "type": "integer"},
        {"name": "wholesale_price", "type": "integer", "role": "price"},
        {"name": "retail_price", "type": "integer"},
        {"name": "shelf_life_days", "type": "integer"},
        {"name": "storage_temp", "type": "text"},
        {"name": "min_stock", "type": "integer"},
        {"name": "is_active", "type": "text", "default": "true"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ]
    },
    "inventory": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "product_id", "type": "integer", "ref": "products"},
        {"name": "batch_number", "type": "text"},
        {"name": "quantity", "type": "integer"},
        {"name": "expiry_date", "type": "text"},
        {"name": "warehouse", "type": "text"},
        {"name": "status", "type": "text", "default": "available", "role": "status"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["available", "reserved", "expired", "damaged"]
    },
    "contacts": {
      "fields": [
        {"name": "id", "type": "integer", "auto": "increment"},
        {"name": "full_name", "type": "text", "required": true},
        {"name": "phone", "type": "text"},
        {"name": "email", "type": "text"},
        {"name": "address", "type": "text"},
        {"name": "city", "type": "text"},
        {"name": "tax_code", "type": "text"},
        {"name": "type", "type": "text", "default": "retailer"},
        {"name": "status", "type": "text", "default": "active", "role": "status"},
        {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
      ],
      "statuses": ["lead", "active", "inactive"]
    }
  },
  "primary": "orders",
  "timezone": "Asia/Ho_Chi_Minh"
}
