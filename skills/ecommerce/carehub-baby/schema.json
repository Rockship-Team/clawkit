{
  "table": "orders",
  "timezone": "Asia/Ho_Chi_Minh",
  "images_dir": "products",
  "fields": [
    {"name": "id", "type": "integer", "auto": "increment"},
    {"name": "status", "type": "text", "default": "new", "role": "status"},
    {"name": "customer_name", "type": "text"},
    {"name": "customer_phone", "type": "text"},
    {"name": "customer_zalo_id", "type": "text", "role": "owner"},
    {"name": "customer_zalo_name", "type": "text"},
    {"name": "customer_address", "type": "text"},
    {"name": "items", "type": "text"},
    {"name": "quantity", "type": "integer"},
    {"name": "baby_age", "type": "text"},
    {"name": "price", "type": "integer", "role": "price"},
    {"name": "note", "type": "text"},
    {"name": "payment_status", "type": "text", "default": "unpaid"},
    {"name": "deposit_amount", "type": "integer", "default": "0"},
    {"name": "created_at", "type": "text", "auto": "timestamp", "role": "timestamp"}
  ],
  "statuses": ["new", "completed", "cancelled"]
}
